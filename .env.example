# FastAPI Server Configuration
PROJECT_NAME="Neural-Geolocated Disaster Splatting"
API_V1_STR="/api/v1"

# Database Configuration
# Dev (SQLite): sqlite:///./disaster_splats.db
# Prod (PostGIS/Docker): postgresql://gis_user:gis_pass@db:5432/gis_db
DATABASE_URL=sqlite:///./disaster_splats.db

# Task Queue (Redis)
# Dev: redis://localhost:6379/0
# Prod (Docker): redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# External 3D Reconstruction API
LUMA_API_KEY=your_luma_ai_api_token_here
LUMA_API_URL=https://api.luma.ai/public/v1

# AWS Storage Configuration (Optional)
AWS_ACCESS_KEY_ID=your_aws_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
